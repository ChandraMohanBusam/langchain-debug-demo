# ============================================================
# langchain-debug-demo - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# OpenAI API Key (required for both agents)
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# Slack Incoming Webhook (used by langchain_agent)
# See README.md -> Section 3 for setup guide
# Format: https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXX
# ------------------------------------------------------------
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ------------------------------------------------------------
# Microsoft Teams Incoming Webhook (used by langgraph_agent)
# See README.md -> Section 4 for setup guide
# Format: https://your-org.webhook.office.com/webhookb2/...
# ------------------------------------------------------------
TEAMS_WEBHOOK_URL=your_teams_webhook_url_here
